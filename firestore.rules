rules_version = '2';

// Firestore Security Rules for M-Expense Flow
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if premium subscription is active
    function hasActivePremium(userId) {
      // Check if user document exists first
      return exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.get('isPremium', false) == true && 
             (get(/databases/$(database)/documents/users/$(userId)).data.get('premiumExpiryDate', null) == null || 
              get(/databases/$(database)/documents/users/$(userId)).data.premiumExpiryDate > request.time);
    }
    
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // User subcollections - inherit parent permissions with additional validations
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Quick budgets with freemium limits (3 max for free users)
      match /budgets/{budgetId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Savings goals with freemium limits (3 max for free users)
      match /savings_goals/{goalId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Comprehensive budgets - Premium only for creation/editing, but allow reading
      match /comprehensive_budgets/{budgetId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId && hasActivePremium(userId);
      }
      
      // Overspending trackers with freemium limits (1 max for free users)
      match /overspending_trackers/{trackerId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Anomaly alerts
      match /anomaly_alerts/{alertId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /achievements/{achievementId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // XP log for gamification tracking
      match /xp_log/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /challenges/{challengeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /missions/{missionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // AI insights with premium restrictions
      match /ai_insights/{insightId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId &&
                     (resource == null || resource.data.get('isPremium', false) != true || hasActivePremium(userId));
      }
      
      // Business profile - Premium only
      match /business_profile {
        allow read, write: if request.auth != null && request.auth.uid == userId && hasActivePremium(userId);
      }
      
      // Business transactions - Premium only
      match /business_transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId && hasActivePremium(userId);
      }
      
      match /settings/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // User preferences (settings subcollection)
      match /settings/preferences {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Onboarding data
      match /onboarding/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Streak reminders
      match /streak_reminders/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Budget alert state (tracks last alert sent per budget)
      match /budget_alert_state/{budgetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Trial data
      match /trials/{trialId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Notifications collection (top-level, written by app and Cloud Functions)
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && 
                         resource.data.get('userId', '') == request.auth.uid;
      allow create: if request.auth != null &&
                    request.resource.data.get('userId', '') == request.auth.uid;
    }
    
    // Leaderboards are read-only for authenticated users
    // Only Cloud Functions can write to leaderboards
    match /leaderboards/{period}/entries/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Global collections are read-only for authenticated users
    // Only admin/Cloud Functions can write
    match /global/{document} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin can write
      
      // Allow reading subcollections
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}